# ============================================
# UI自动化测试框架 - 环境变量配置模板
# 使用方式：复制本文件为 .env 并按需修改
# ============================================

# 测试环境：dev / test / staging / prod
ENV=test

# 基础URL（各环境对应不同地址）
BASE_URL=https://test.example.com

# 浏览器类型：chromium / firefox / webkit
BROWSER=chromium

# 是否无头模式运行
HEADLESS=false

# 视口大小（宽x高）
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# 默认超时时间（毫秒）
TIMEOUT=30000

# 失败重试次数
RETRY_TIMES=2

# 并行执行worker数量（auto=CPU核数）
PARALLEL_WORKERS=auto

# 是否启用Trace记录（retain-on-failure / on / off）
TRACE_MODE=retain-on-failure

# Allure报告目录
ALLURE_RESULTS_DIR=reports/allure-results

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 截图保存目录
SCREENSHOT_DIR=reports/screenshots

# Trace保存目录
TRACE_DIR=reports/traces
